{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnlyInventory",
      "Effect": "Allow",
      "Action": [
        "cloudtrail:LookupEvents",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "ec2:Describe*",
        "iam:Get*",
        "iam:List*",
        "logs:Describe*",
        "logs:FilterLogEvents",
        "s3:GetBucketLocation",
        "s3:GetBucketPolicyStatus",
        "s3:ListAllMyBuckets",
        "s3:ListBucket"
      ],
      "Resource": "*"
    }
  ]
}

