{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadOnlyOperationalContext",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "ec2:Describe*",
        "logs:Describe*",
        "logs:FilterLogEvents",
        "s3:GetBucketLocation",
        "s3:ListAllMyBuckets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowTaggedInstanceOperations",
      "Effect": "Allow",
      "Action": [
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:RebootInstances"
      ],
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/ManagedBy": "iam-access-lifecycle-lab"
        }
      }
    },
    {
      "Sid": "AllowLabAlarmOperations",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricAlarm",
        "cloudwatch:DeleteAlarms",
        "cloudwatch:DisableAlarmActions",
        "cloudwatch:EnableAlarmActions"
      ],
      "Resource": "arn:aws:cloudwatch:*:*:alarm:iam-lifecycle-*"
    },
    {
      "Sid": "AllowLabLogWrites",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:logs:*:*:log-group:/aws/iam-lifecycle-lab/*:*",
        "arn:aws:s3:::iam-lifecycle-lab-*",
        "arn:aws:s3:::iam-lifecycle-lab-*/*"
      ]
    },
    {
      "Sid": "DenyIdentityMutation",
      "Effect": "Deny",
      "Action": [
        "iam:Attach*",
        "iam:CreateAccessKey",
        "iam:CreateLoginProfile",
        "iam:CreatePolicyVersion",
        "iam:CreateUser",
        "iam:Delete*",
        "iam:Detach*",
        "iam:PassRole",
        "iam:Put*",
        "iam:SetDefaultPolicyVersion",
        "iam:Update*",
        "organizations:*"
      ],
      "Resource": "*"
    }
  ]
}
